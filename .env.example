# Model
MODEL_TYPE=efficientnet_b4
MODEL_WEIGHTS_PATH=./models/weights/efficientnet_b4_best.pth
MODEL_CLASS_NAMES_PATH=./data/processed/plantvillage/train
NUM_CLASSES=16
CONFIDENCE_THRESHOLD=0.7

# Ollama / VLM
OLLAMA_BASE_URL=http://localhost:11434
VLM_MODEL=llava:7b
VLM_TIMEOUT_SECONDS=25

# ChromaDB
CHROMA_PERSIST_DIR=./data/chroma_db
CHROMA_COLLECTION_NAME=crop_knowledge

# Translation
DEFAULT_LANGUAGE=en
INDICTRANS_MODEL_DIR=./models/indictrans2

# TTS
TTS_ENGINE=bark
BARK_MODEL_DIR=./models/bark

# API
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=["http://localhost:5173", "http://localhost:5174"]

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_BACKEND_STORE_URI=./mlruns
